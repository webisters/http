{
    "name": "webisters/http",
    "description": "Webisters HTTP Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "http",
        "anti-csrf",
        "csrf",
        "message",
        "request",
        "response",
        "url",
        "cookie",
        "user-agent",
        "download",
        "rest"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/http",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/http/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/http",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-fileinfo": "*",
        "ext-json": "*",
        "webisters/debug": "*",
        "webisters/helpers": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\HTTP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\HTTP\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


